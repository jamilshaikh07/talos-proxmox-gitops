{
    "meta": {
        "lastTouchedVersion": "2026.6.10"
    },
    "gateway": {
        "port": 18789,
        "mode": "local",
        "bind": "auto",
        "auth": {
            "mode": "token",
            "token": "REPLACE_WITH_GATEWAY_TOKEN"
        },
        "tailscale": {
            "mode": "off",
            "resetOnExit": false
        }
    },
    "agents": {
        "defaults": {
            "model": {
                "primary": "deepseek/deepseek-v4-flash"
            },
            "models": {
                "anthropic/claude-haiku-4-5-20251001": {},
                "anthropic/claude-sonnet-4-6": {},
                "deepseek/deepseek-v4-flash": {}
            },
            "workspace": "/home/node/.openclaw/workspace",
            "compaction": {
                "mode": "safeguard"
            },
            "maxConcurrent": 4,
            "subagents": {
                "maxConcurrent": 8
            }
        }
    },
    "models": {
        "providers": {}
    },
    "plugins": {
        "allow": ["mattermost"],
        "bundledDiscovery": "compat",
        "entries": {
            "mattermost": {
                "enabled": true
            }
        }
    },
    "messages": {
        "ackReactionScope": "group-mentions"
    },
    "commands": {
        "native": "auto",
        "nativeSkills": "auto",
        "restart": true,
        "ownerDisplay": "raw"
    },
    "hooks": {
        "internal": {
            "enabled": true,
            "entries": {
                "session-memory": {
                    "enabled": true
                }
            }
        }
    },
    "channels": {
        "mattermost": {
            "enabled": true,
            "baseUrl": "http://mattermost.mattermost.svc.cluster.local:8065",
            "botToken": "REPLACE_WITH_MATTERMOST_BOT_TOKEN",
            "chatmode": "oncall",
            "dmPolicy": "pairing",
            "groupPolicy": "allowlist",
            "groupAllowFrom": ["*"],
            "network": {
                "dangerouslyAllowPrivateNetwork": true
            },
            "groups": {
                "837zg4t6wjb17m4n9w49j5mq3w": {
                    "requireMention": false
                }
            }
        }
    }
}
