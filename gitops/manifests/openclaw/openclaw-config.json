{
    "meta": {
        "lastTouchedVersion": "2026.6.10"
    },
    "gateway": {
        "port": 18789,
        "mode": "local",
        "bind": "auto",
        "auth": {
            "mode": "token",
            "token": "REPLACE_WITH_GATEWAY_TOKEN"
        },
        "tailscale": {
            "mode": "off",
            "resetOnExit": false
        }
    },
    "agents": {
        "defaults": {
            "model": {
                "primary": "anthropic/claude-haiku-4-5-20251001"
            },
            "models": {
                "anthropic/claude-haiku-4-5-20251001": {},
                "anthropic/claude-sonnet-4-6": {}
            },
            "workspace": "/home/node/.openclaw/workspace",
            "compaction": {
                "mode": "safeguard"
            },
            "maxConcurrent": 4,
            "subagents": {
                "maxConcurrent": 8
            }
        }
    },
    "models": {
        "providers": {}
    },
    "messages": {
        "ackReactionScope": "group-mentions"
    },
    "commands": {
        "native": "auto",
        "nativeSkills": "auto",
        "restart": true,
        "ownerDisplay": "raw"
    },
    "hooks": {
        "internal": {
            "enabled": true,
            "entries": {
                "session-memory": {
                    "enabled": true
                }
            }
        }
    },
    "channels": {
        "mattermost": {
            "enabled": true,
            "baseUrl": "https://mattermost.jamilshaikh.in",
            "botToken": "REPLACE_WITH_MATTERMOST_BOT_TOKEN",
            "chatmode": "oncall",
            "dmPolicy": "pairing"
        }
    }
}
